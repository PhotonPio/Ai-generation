# Backend auth (default: admin / changeme)
API_USER=admin
API_PASS=changeme
AUTH_ENABLED=true

# Ollama (local LLM for script generation)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# Image generation (optional — app still works without these)
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# Stable Diffusion A1111 (optional, for AI-generated images instead of stock photos)
A1111_URL=http://127.0.0.1:7860/sdapi/v1/txt2img

# Video settings
TRANSITION_STYLE=kenburns
SD_STEPS=20
MAX_WORKERS_CPU=4
